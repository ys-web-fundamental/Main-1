# Database — uses service name 'db' as host inside Docker network
DATABASE_URL=mysql+aiomysql://pscms:secret@db:3306/profit_portal

# Redis — uses service name 'redis' as host
REDIS_URL=redis://redis:6379

# JWT — change this to a long random string in production
JWT_SECRET=change-me-to-a-long-random-secret-key

# CORS — frontend origin
CORS_ORIGINS=["http://localhost:5173"]
