# ── Environment variables template ──────────────────────────────────────
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to source control (.gitignore must include it).
# All VITE_ variables are bundled into the client — never put real secrets here.
# ────────────────────────────────────────────────────────────────────────

# ── API ─────────────────────────────────────────────────────────────────
# Base URL for all API calls (empty = mock data used, no network calls)
VITE_API_BASE_URL=

# Auth endpoint paths (relative to VITE_API_BASE_URL)
VITE_AUTH_LOGIN_ENDPOINT=/auth/login
VITE_AUTH_OTP_ENDPOINT=/auth/verify-otp
VITE_AUTH_LOGOUT_ENDPOINT=/auth/logout

# ── Session ──────────────────────────────────────────────────────────────
# sessionStorage key prefix for JWT token and user object.
# The token is stored as VITE_SESSION_KEY and user as VITE_SESSION_KEY_user.
VITE_SESSION_KEY=pscms_session

# ── Demo credentials (development / staging ONLY) ───────────────────────
# Used exclusively in authService mock mode (DEMO_USERS table).
# One pair per role. Remove all from .env.local once real API auth is wired up.
VITE_DEMO_AGRONOMIST_MOBILE=
VITE_DEMO_AGRONOMIST_PASSWORD=
VITE_DEMO_SUPERVISOR_MOBILE=
VITE_DEMO_SUPERVISOR_PASSWORD=
VITE_DEMO_ADMIN_MOBILE=
VITE_DEMO_ADMIN_PASSWORD=
VITE_DEMO_DEO_MOBILE=
VITE_DEMO_DEO_PASSWORD=
VITE_DEMO_MANAGER_MOBILE=
VITE_DEMO_MANAGER_PASSWORD=

# ── App ──────────────────────────────────────────────────────────────────
VITE_APP_ENV=development
