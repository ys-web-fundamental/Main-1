# Backend API — points to FastAPI container inside Docker
VITE_API_BASE_URL=http://localhost:8000

# Auth endpoints
VITE_AUTH_LOGIN_ENDPOINT=/auth/login
VITE_AUTH_OTP_ENDPOINT=/auth/verify-otp
VITE_AUTH_LOGOUT_ENDPOINT=/auth/logout

# Session storage key for JWT
VITE_SESSION_KEY=pscms_session

# Enable file-watch polling so Vite HMR works inside Docker on Windows
CHOKIDAR_USEPOLLING=true
