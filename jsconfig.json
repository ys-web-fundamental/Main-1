{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@components/*": ["src/components/*"],
      "@features/*": ["src/components/features/*"],
      "@common/*": ["src/components/common/*"],
      "@layout/*": ["src/components/layout/*"],
      "@hooks/*": ["src/hooks/*"],
      "@context/*": ["src/context/*"],
      "@constants/*": ["src/constants/*"],
      "@data/*":       ["src/data/*"],
      "@assets/*":     ["src/assets/*"],
      "@services/*":   ["src/services/*"],
      "@ui/*":         ["src/components/ui/*"],
      "@lib/*":        ["src/lib/*"]
    }
  }
}
